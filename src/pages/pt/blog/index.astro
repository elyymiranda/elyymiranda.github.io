---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const fmt = new Intl.DateTimeFormat('pt-BR', { dateStyle: 'long', timeZone: 'UTC' });
---
<Base lang="pt" title="Blog" altUrl="/en/blog/">
  <h1>Blog</h1>
  <p>Textos de divulgação científica e de política.</p>
  <ul class="pubs">
    {posts.map((post) => (
      <li class="card">
        <a href={`/pt/blog/${post.id}/`}><strong>{post.data.title}</strong></a>
        <div class="post-date">
          <span class="tag">{post.data.category}</span> · {fmt.format(post.data.date)}
        </div>
        {post.data.description && <p>{post.data.description}</p>}
      </li>
    ))}
  </ul>
</Base>
